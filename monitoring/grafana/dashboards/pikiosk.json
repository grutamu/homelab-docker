{
  "title": "Pi Kiosk",
  "uid": "pikiosk",
  "version": 1,
  "refresh": "1m",
  "panels": [
    {
      "title": "MPV Running",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "Down", "color": "red"}, "1": {"text": "Running", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{"expr": "pikiosk_mpv_running{device=\"pikiosk\"}", "instant": true}]
    },
    {
      "title": "Throttle Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "Healthy", "color": "green"}}},
            {"type": "range", "options": {"from": 1, "to": 999999999, "result": {"text": "Throttled", "color": "red"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{"expr": "pikiosk_throttled_status{device=\"pikiosk\"}", "instant": true}]
    },
    {
      "title": "CPU Temperature",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 8, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 90,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 60}, {"color": "red", "value": 80}]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{"expr": "pikiosk_cpu_temperature_celsius{device=\"pikiosk\"}", "instant": true}]
    },
    {
      "title": "ARM Frequency",
      "type": "stat",
      "gridPos": {"h": 4, "w": 5, "x": 14, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": 0}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{"expr": "pikiosk_arm_frequency_hz{device=\"pikiosk\"}", "instant": true}]
    },
    {
      "title": "Stream URL",
      "type": "stat",
      "gridPos": {"h": 4, "w": 5, "x": 19, "y": 0},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": 0}]},
          "color": {"mode": "fixed", "fixedColor": "blue"}
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "name"
      },
      "targets": [{"expr": "pikiosk_stream_info{device=\"pikiosk\"}", "instant": true, "legendFormat": "{{url}}"}]
    },
    {
      "title": "CPU Temperature Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 60}, {"color": "red", "value": 80}]
          }
        }
      },
      "targets": [{"expr": "pikiosk_cpu_temperature_celsius{device=\"pikiosk\"}", "legendFormat": "Temperature"}]
    },
    {
      "title": "ARM Frequency Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "hertz"}},
      "targets": [{"expr": "pikiosk_arm_frequency_hz{device=\"pikiosk\"}", "legendFormat": "ARM Frequency"}]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "targets": [{"expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{device=\"pikiosk\", mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %"}]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes{device=\"pikiosk\"} - node_memory_MemAvailable_bytes{device=\"pikiosk\"}", "legendFormat": "Used"},
        {"expr": "node_memory_MemTotal_bytes{device=\"pikiosk\"}", "legendFormat": "Total"}
      ]
    },
    {
      "title": "WiFi Link",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 20},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "Down", "color": "red"}, "1": {"text": "Up", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{"expr": "node_network_carrier{device=\"wlan0\", instance=\"100.86.212.93:9100\"}", "instant": true}]
    },
    {
      "title": "WiFi Carrier Changes",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 20},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 2}, {"color": "red", "value": 5}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{"expr": "node_network_carrier_changes_total{device=\"wlan0\", instance=\"100.86.212.93:9100\"}", "instant": true}]
    },
    {
      "title": "WiFi Throughput",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 20},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "irate(node_network_receive_bytes_total{device=\"wlan0\", instance=\"100.86.212.93:9100\"}[5m])", "legendFormat": "RX"},
        {"expr": "irate(node_network_transmit_bytes_total{device=\"wlan0\", instance=\"100.86.212.93:9100\"}[5m])", "legendFormat": "TX"}
      ]
    },
    {
      "title": "WiFi Errors & Drops",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}
        }
      },
      "targets": [
        {"expr": "irate(node_network_receive_errs_total{device=\"wlan0\", instance=\"100.86.212.93:9100\"}[5m])", "legendFormat": "RX Errors"},
        {"expr": "irate(node_network_transmit_errs_total{device=\"wlan0\", instance=\"100.86.212.93:9100\"}[5m])", "legendFormat": "TX Errors"},
        {"expr": "irate(node_network_receive_drop_total{device=\"wlan0\", instance=\"100.86.212.93:9100\"}[5m])", "legendFormat": "RX Drops"},
        {"expr": "irate(node_network_transmit_drop_total{device=\"wlan0\", instance=\"100.86.212.93:9100\"}[5m])", "legendFormat": "TX Drops"}
      ]
    }
  ]
}
